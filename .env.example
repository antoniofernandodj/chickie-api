# Production Environment Variables
# Copy this file to .env and fill in your production values
# DO NOT commit .env to version control!

# PostgreSQL
POSTGRES_USER=your_production_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=chickie_production

# Database URL (for application)
DATABASE_URL=postgres://your_production_user:your_secure_password_here@postgres:5432/chickie_production

# JWT Secret (use a strong random string)
JWT_SECRET=your_very_secure_jwt_secret_key_here

# RabbitMQ
RABBITMQ_USER=chickie_production
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://chickie_production:your_rabbitmq_password_here@rabbitmq:5672

# S3 / MinIO Configuration (production)
S3_BUCKET_NAME_1=your-production-bucket
S3_ENDPOINT=https://s3.your-provider.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
