# ============================================================
# Chickie CLI - Complete Test Suite
# ============================================================
# Runs ALL test files in sequential order.
# Tests MUST run in order: database → auth → lojas → everything else
#
# Run with:
#   clurl all-tests.aggregation.clurl
#   clurl --stop-on-fail all-tests.aggregation.clurl
#   clurl --verbose all-tests.aggregation.clurl
# ============================================================

[group]
# Phase 1: Setup (MUST run first)
01-database-setup.clurl
02-auth.clurl
03-lojas.clurl

# Phase 2: Domain CRUD (depends on Phase 1)
04-produtos.clurl
05-categorias.clurl
06-adicionais.clurl
07-pedidos.clurl
08-cupons.clurl
09-promocoes.clurl
10-avaliacoes.clurl
11-favoritos.clurl
12-horarios.clurl
13-config-pedido.clurl
14-ingredientes.clurl

# Phase 3: Advanced Operations (depends on Phase 1-2)
15-funcionarios.clurl
16-enderecos-loja.clurl
17-driver-assignment.clurl

# Phase 4: Error Handling & Integration (Final)
18-error-handling.clurl
19-integration-order-flow.clurl
20-environment.clurl

# Cleanup
01-database-setup.clurl

[Options]
# Stop executing test files when one fails
stop-on-fail = false

# Enable verbose output for all test files (set to true for debugging)
verbose = false
