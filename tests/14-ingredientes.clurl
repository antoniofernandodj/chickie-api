# ============================================================
# Ingredients Tests
# Uses stores from previous tests
# ============================================================

# --- Create an ingredient ---
RUN cargo run --quiet -p cli -- \
    create-ingrediente \
    --loja-uuid {{main_store_uuid}} \
    --nome "Tomate" \
    --descricao "Tomate fresco" \
    --preco 2.50

[Captures]
ingrediente_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Tomate"

# --- List ingredients ---
RUN cargo run --quiet -p cli -- \
    list-ingredientes \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Tomate"

# --- Delete ingredient ---
RUN cargo run --quiet -p cli -- \
    delete-ingrediente \
    {{ingrediente_uuid}}

[Asserts]
exit-code == 0
