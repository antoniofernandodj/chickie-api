# ============================================================
# Product (Produto) Tests
# Uses stores and users from previous tests
# ============================================================

# --- Create a category for products ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{product_store_uuid}} \
    --nome "Test Category" \
    --ordem 1

[Captures]
categoria_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Category"

# --- Create a product ---
RUN cargo run --quiet -p chickie-cli -- \
    create-produto \
    --loja-uuid {{product_store_uuid}} \
    --categoria-uuid {{categoria_uuid}} \
    --nome "Test Product" \
    --preco 29.90 \
    --disponivel \
    --tempo-preparo-min 20

[Captures]
produto_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Product"

# --- List products by store ---
RUN cargo run --quiet -p chickie-cli -- \
    list-produtos-por-loja \
    --loja-uuid {{product_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Test Product"

# --- Update product ---
RUN cargo run --quiet -p chickie-cli -- \
    update-produto \
    {{produto_uuid}} \
    --nome "Updated Product" \
    --descricao "Updated description" \
    --preco 39.90 \
    --categoria-uuid {{categoria_uuid}} \
    --tempo-preparo-min 25

[Asserts]
exit-code == 0
stdout contains "Updated Product"

# --- Delete product ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-produto \
    {{produto_uuid}}

[Asserts]
exit-code == 0

# ============================================================
# Product Availability & Category Listing Tests
# ============================================================

# --- Create category for availability test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{main_store_uuid}} \
    --nome "Availability Test Category" \
    --ordem 100

[Captures]
avail_categoria_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Availability Test Category"

# --- Create product in the category ---
RUN cargo run --quiet -p chickie-cli -- \
    create-produto \
    --loja-uuid {{main_store_uuid}} \
    --categoria-uuid {{avail_categoria_uuid}} \
    --nome "Availability Product" \
    --preco 25.0 \
    --disponivel \
    --tempo-preparo-min 20

[Captures]
avail_produto_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Availability Product"

# --- List products by category ---
RUN cargo run --quiet -p chickie-cli -- \
    list-produtos-por-categoria \
    {{avail_categoria_uuid}}

[Asserts]
exit-code == 0
stdout contains "Availability Product"

# --- Set product as unavailable ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-produto \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{avail_produto_uuid}} \
    --disponivel false

[Asserts]
exit-code == 0
stdout contains "indisponível"

# --- Set product as available again ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-produto \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{avail_produto_uuid}} \
    --disponivel true

[Asserts]
exit-code == 0
stdout contains "disponível"

# --- Clean up product ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-produto \
    {{avail_produto_uuid}}

[Asserts]
exit-code == 0

# --- Clean up category ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-categoria \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{avail_categoria_uuid}}

[Asserts]
exit-code == 0
