# ============================================================
# New CLI Commands Tests
# Tests all commands implemented in the CLI expansion:
# - User email/username availability checks
# - Store slug availability check
# - Add-ons availability listing
# - Products by category listing
# - Add-on and product availability toggling
# - Employee delete and credential changes
# - Delivery driver delete, available list, credential changes, availability toggle
# - User address CRUD operations
# - Store address update and delete
# - Employee and driver update operations
# - Promotion update operations
# - Order with delivery and driver removal
# ============================================================

# ============================================================
# User Availability Tests
# ============================================================

# --- Create test user for availability tests ---
RUN cargo run --quiet -p chickie-cli -- \
    signup \
    --nome "Availability User" \
    --username "availuser" \
    --senha "availpass123" \
    --email "avail@test.com" \
    --celular "11944444444"

[Asserts]
exit-code == 0

# --- Verify email NOT available (already taken) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-email-disponivel "avail@test.com"

[Asserts]
exit-code == 0
stderr contains "já está em uso"

# --- Verify email IS available (new email) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-email-disponivel "unique-new-email@test.com"

[Asserts]
exit-code == 0
stdout contains "está disponível"

# --- Verify username NOT available (already taken) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-username-disponivel "availuser"

[Asserts]
exit-code == 0
stderr contains "já está em uso"

# --- Verify username IS available (new username) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-username-disponivel "unique-username-xyz"

[Asserts]
exit-code == 0
stdout contains "está disponível"

# ============================================================
# Store Slug Availability Tests
# ============================================================

# --- Verify slug NOT available (already taken) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-slug-disponivel "main-test-store"

[Asserts]
exit-code == 0
stderr contains "já está em uso"

# --- Verify slug IS available (new slug) ---
RUN cargo run --quiet -p chickie-cli -- \
    verificar-slug-disponivel "brand-new-slug-xyz-123"

[Asserts]
exit-code == 0
stdout contains "está disponível"

# ============================================================
# Address Tests - User
# ============================================================

# --- Create user address ---
RUN cargo run --quiet -p chickie-cli -- \
    create-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    --logradouro "Test Avenue" \
    --numero "100" \
    --bairro "Test District" \
    --cidade "Testopolis" \
    --estado "SP" \
    --cep "12345-000" \
    --complemento "Apto 42"

[Captures]
user_endereco_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Endereço de usuário criado"
stdout contains "Test Avenue"

# --- List user addresses ---
RUN cargo run --quiet -p chickie-cli -- \
    list-enderecos-usuario \
    {{user_uuid}}

[Asserts]
exit-code == 0
stdout contains "Test Avenue"

# --- Get user address ---
RUN cargo run --quiet -p chickie-cli -- \
    get-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    {{user_endereco_uuid}}

[Asserts]
exit-code == 0
stdout contains "Test Avenue"
stdout contains "Apto 42"

# --- Update user address ---
RUN cargo run --quiet -p chickie-cli -- \
    update-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    --logradouro "Updated Avenue" \
    --numero "200" \
    {{user_endereco_uuid}}

[Asserts]
exit-code == 0
stdout contains "Endereço de usuário atualizado"

# --- Verify updated address ---
RUN cargo run --quiet -p chickie-cli -- \
    get-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    {{user_endereco_uuid}}

[Asserts]
exit-code == 0
stdout contains "Updated Avenue"
stdout contains "200"

# --- Delete user address ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    {{user_endereco_uuid}}

[Asserts]
exit-code == 0
stdout contains "Endereço de usuário deletado"

# --- Verify deleted address is gone ---
RUN cargo run --quiet -p chickie-cli -- \
    get-endereco-usuario \
    --usuario-uuid {{user_uuid}} \
    {{user_endereco_uuid}}

[Asserts]
exit-code == 0
stderr contains "não encontrado"

# ============================================================
# Address Tests - Store (Update/Delete)
# ============================================================

# --- Create store address for update test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-endereco-loja \
    --loja-uuid {{main_store_uuid}} \
    --logradouro "Update Street" \
    --numero "999" \
    --bairro "Update District" \
    --cidade "Update City" \
    --estado "MG" \
    --cep "30000-000"

[Captures]
store_endereco_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Endereço de loja criado"

# --- List to capture the address uuid from response ---
RUN cargo run --quiet -p chickie-cli -- \
    list-enderecos-loja \
    {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Update Street"

# --- Update store address ---
RUN cargo run --quiet -p chickie-cli -- \
    update-endereco-loja \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{store_endereco_uuid}} \
    --logradouro "Updated Store Street" \
    --numero "1000" \
    --bairro "Updated District" \
    --cidade "Updated City"

[Asserts]
exit-code == 0
stdout contains "Endereço de loja atualizado"

# --- Verify updated store address ---
RUN cargo run --quiet -p chickie-cli -- \
    list-enderecos-loja \
    {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Updated Store Street"
stdout contains "Updated City"

# --- Delete store address ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-endereco-loja \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{store_endereco_uuid}}

[Asserts]
exit-code == 0
stdout contains "Endereço de loja deletado"

# ============================================================
# Employee Tests - Update, Delete, Trocar Credenciais
# ============================================================

# --- Add employee for update test ---
RUN cargo run --quiet -p chickie-cli -- \
    add-funcionario \
    --loja-uuid {{main_store_uuid}} \
    --nome "Test Func Update" \
    --username "testfuncupdate" \
    --email "testfuncupdate@test.com" \
    --senha "testfuncpass" \
    --celular "11933333333" \
    --cargo "Supervisor" \
    --salario 4000.0 \
    --data-admissao "2026-06-01"

[Captures]
test_funcionario_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/
test_funcionario_usuario_uuid: stdout regex /"usuario_uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Func Update"
stdout contains "Supervisor"

# --- Update employee ---
RUN cargo run --quiet -p chickie-cli -- \
    update-funcionario \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_funcionario_uuid}} \
    --cargo "Senior Supervisor" \
    --salario 4500.0

[Asserts]
exit-code == 0
stdout contains "Funcionário atualizado"

# --- Verify updated employee ---
RUN cargo run --quiet -p chickie-cli -- \
    list-funcionarios \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Test Func Update"
stdout contains "Senior Supervisor"

# --- Change employee email/password ---
RUN cargo run --quiet -p chickie-cli -- \
    trocar-email-senha-funcionario \
    --usuario-uuid {{test_funcionario_usuario_uuid}} \
    --novo-email "updatedfunc@test.com" \
    --nova-senha "newfuncpass123"

[Asserts]
exit-code == 0
stdout contains "Email/senha do funcionário atualizados"

# --- Delete employee ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-funcionario \
    --uuid {{test_funcionario_uuid}}

[Asserts]
exit-code == 0
stdout contains "Funcionário deletado"

# --- Verify employee is gone ---
RUN cargo run --quiet -p chickie-cli -- \
    list-funcionarios \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout not contains "Test Func Update"

# ============================================================
# Delivery Driver Tests - Update, Delete, Disponiveis, Toggle
# ============================================================

# --- Add driver for update test ---
RUN cargo run --quiet -p chickie-cli -- \
    add-entregador \
    --loja-uuid {{main_store_uuid}} \
    --nome "Test Driver Update" \
    --username "testdriverupdate" \
    --email "testdriverupdate@test.com" \
    --senha "testdriverpass" \
    --celular "11922222222" \
    --veiculo "Bicicleta" \
    --placa "N/A"

[Captures]
test_entregador_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/
test_entregador_usuario_uuid: stdout regex /"usuario_uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Driver Update"
stdout contains "Bicicleta"

# --- Update delivery driver ---
RUN cargo run --quiet -p chickie-cli -- \
    update-entregador \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_entregador_uuid}} \
    --veiculo "Moto" \
    --placa "TEST-9999"

[Asserts]
exit-code == 0
stdout contains "Entregador atualizado"

# --- Verify updated driver ---
RUN cargo run --quiet -p chickie-cli -- \
    list-entregadores \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Moto"
stdout contains "TEST-9999"

# --- Change driver email/password ---
RUN cargo run --quiet -p chickie-cli -- \
    trocar-email-senha-entregador \
    --usuario-uuid {{test_entregador_usuario_uuid}} \
    --novo-email "updateddriver@test.com" \
    --nova-senha "newdriverpass123"

[Asserts]
exit-code == 0
stdout contains "Email/senha do entregador atualizados"

# --- Set driver as unavailable ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-entregador \
    --uuid {{test_entregador_uuid}} \
    --disponivel false

[Asserts]
exit-code == 0
stdout contains "indisponível"

# --- List available drivers (should not show unavailable one) ---
RUN cargo run --quiet -p chickie-cli -- \
    list-entregadores-disponiveis \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
# The unavailable driver should not appear
stdout not contains "TEST-9999"

# --- Set driver as available again ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-entregador \
    --uuid {{test_entregador_uuid}} \
    --disponivel true

[Asserts]
exit-code == 0
stdout contains "disponível"

# --- Delete delivery driver ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-entregador \
    --uuid {{test_entregador_uuid}}

[Asserts]
exit-code == 0
stdout contains "Entregador deletado"

# ============================================================
# Catalog: Adicionais Disponíveis Test
# ============================================================

# --- Create additional for availability test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-adicional \
    --loja-uuid {{main_store_uuid}} \
    --nome "Disponível Test" \
    --descricao "Test availability toggle" \
    --preco 2.00

[Captures]
disp_adicional_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Disponível Test"

# --- List available add-ons (should include the new one) ---
RUN cargo run --quiet -p chickie-cli -- \
    list-adicionais-disponiveis \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Disponível Test"

# --- Set additional as unavailable ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}} \
    --disponivel false

[Asserts]
exit-code == 0
stdout contains "indisponível"

# --- List available add-ons (should NOT include the unavailable one) ---
RUN cargo run --quiet -p chickie-cli -- \
    list-adicionais-disponiveis \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout not contains "Disponível Test"

# --- Set additional as available again ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}} \
    --disponivel true

[Asserts]
exit-code == 0
stdout contains "disponível"

# --- Clean up ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}}

[Asserts]
exit-code == 0

# ============================================================
# Catalog: Produtos por Categoria & Disponibilidade
# ============================================================

# --- Create category for product test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{main_store_uuid}} \
    --nome "Test Products Category" \
    --ordem 100

[Captures]
test_categoria_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Products Category"

# --- Create product in the category ---
RUN cargo run --quiet -p chickie-cli -- \
    create-produto \
    --loja-uuid {{main_store_uuid}} \
    --categoria-uuid {{test_categoria_uuid}} \
    --nome "Test Category Product" \
    --preco 25.0 \
    --disponivel true \
    --tempo-preparo-min 20 \
    --destaque false

[Captures]
test_produto_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Category Product"

# --- List products by category ---
RUN cargo run --quiet -p chickie-cli -- \
    list-produtos-por-categoria \
    {{test_categoria_uuid}}

[Asserts]
exit-code == 0
stdout contains "Test Category Product"

# --- Set product as unavailable ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-produto \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_produto_uuid}} \
    --disponivel false

[Asserts]
exit-code == 0
stdout contains "indisponível"

# --- Set product as available again ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-produto \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_produto_uuid}} \
    --disponivel true

[Asserts]
exit-code == 0
stdout contains "disponível"

# --- Clean up product ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-produto \
    {{test_produto_uuid}}

[Asserts]
exit-code == 0

# --- Clean up category ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-categoria \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_categoria_uuid}}

[Asserts]
exit-code == 0

# ============================================================
# Marketing: Update Promocao Test
# ============================================================

# --- Create promotion for update test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-promocao \
    --loja-uuid {{main_store_uuid}} \
    --nome "Test Promo Update" \
    --descricao "Original description" \
    --tipo-desconto "percentual" \
    --valor-desconto 10.0 \
    --data-inicio "2026-01-01T00:00:00Z" \
    --data-fim "2026-12-31T23:59:59Z" \
    --dias-semana 1 2 3 4 5 \
    --tipo-escopo "loja" \
    --prioridade 1

[Captures]
test_promocao_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Test Promo Update"
stdout contains "Original description"

# --- Update promotion ---
RUN cargo run --quiet -p chickie-cli -- \
    update-promocao \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{test_promocao_uuid}} \
    --nome "Updated Test Promo" \
    --descricao "Updated description" \
    --valor-desconto 15.0

[Asserts]
exit-code == 0
stdout contains "Promoção atualizada"

# --- Verify updated promotion ---
RUN cargo run --quiet -p chickie-cli -- \
    list-promocoes \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Updated Test Promo"
stdout contains "Updated description"

# --- Clean up promotion ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-promocao \
    {{test_promocao_uuid}}

[Asserts]
exit-code == 0
stdout contains "Promoção deletada"

# ============================================================
# Pedidos: Remove Entregador Test
# ============================================================

# --- Add driver for order test ---
RUN cargo run --quiet -p chickie-cli -- \
    add-entregador \
    --loja-uuid {{order_store_uuid}} \
    --nome "Order Driver" \
    --username "orderdriver" \
    --email "orderdriver@test.com" \
    --senha "orderdriverpass" \
    --celular "11988777777" \
    --veiculo "Moto" \
    --placa "ORD-1234"

[Captures]
order_entregador_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0

# --- Create order for testing ---
RUN cargo run --quiet -p chickie-cli -- \
    create-pedido \
    --usuario-uuid {{order_user_uuid}} \
    --loja-uuid {{order_store_uuid}} \
    --taxa-entrega 5.0 \
    --subtotal 30.0 \
    --forma-pagamento "PIX"

[Captures]
test_pedido_uuid: stdout regex /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/

[Asserts]
exit-code == 0

# --- Assign driver to order ---
RUN cargo run --quiet -p chickie-cli -- \
    atribuir-entregador \
    --pedido-uuid {{test_pedido_uuid}} \
    --loja-uuid {{order_store_uuid}} \
    --entregador-uuid {{order_entregador_uuid}}

[Asserts]
exit-code == 0
stdout contains "Entregador atribuído"

# --- Remove driver from order ---
RUN cargo run --quiet -p chickie-cli -- \
    remover-entregador \
    --pedido-uuid {{test_pedido_uuid}} \
    --loja-uuid {{order_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Entregador removido do pedido"
