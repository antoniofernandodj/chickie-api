# ============================================================
# Database Setup Tests
# MUST run first - wipes database and applies migrations
# ============================================================

# --- Wipe database (clean slate) ---
RUN cargo run -p cli -- wipe

[Asserts]
exit-code == 0
stdout contains "Todas as tabelas removidas"

# --- Apply migrations ---
RUN cargo run -p cli -- migrate

[Asserts]
exit-code == 0
stdout contains "Migrações aplicadas com sucesso"
