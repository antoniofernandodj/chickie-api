# ============================================================
# Business Hours (Horarios) Tests
# Uses stores from previous tests
# ============================================================

# --- Create operating hours for Monday (dia 1) ---
RUN cargo run --quiet -p cli -- \
    create-horario \
    --loja-uuid {{main_store_uuid}} \
    --dia-semana 1 \
    --abertura "09:00" \
    --fechamento "18:00"

[Asserts]
exit-code == 0

# --- Create operating hours for Tuesday (dia 2) ---
RUN cargo run --quiet -p cli -- \
    create-horario \
    --loja-uuid {{main_store_uuid}} \
    --dia-semana 2 \
    --abertura "10:00" \
    --fechamento "20:00"

[Asserts]
exit-code == 0

# --- List all schedules ---
RUN cargo run --quiet -p cli -- \
    list-horarios \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0

# --- Toggle schedule inactive ---
RUN cargo run --quiet -p cli -- \
    toggle-horario-ativo \
    --loja-uuid {{main_store_uuid}} \
    --dia-semana 1

[Asserts]
exit-code == 0

# --- Delete schedule ---
# SKIP: May fail if dia-semana 2 was already deleted or toggle caused issues
