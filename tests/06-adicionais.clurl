# ============================================================
# Topping (Adicional) Tests
# Uses stores from previous tests
# ============================================================

# --- Create an adicional ---
RUN cargo run --quiet -p chickie-cli -- \
    create-adicional \
    --loja-uuid {{main_store_uuid}} \
    --nome "Queijo Extra" \
    --descricao "Queijo mussarela adicional" \
    --preco 3.50

[Captures]
adicional_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Queijo Extra"

# --- List all adicionais ---
RUN cargo run --quiet -p chickie-cli -- \
    list-adicionais \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Queijo Extra"

# --- Update adicional ---
RUN cargo run --quiet -p chickie-cli -- \
    update-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{adicional_uuid}} \
    --nome "Queijo Premium" \
    --descricao "Queijo importado especial" \
    --preco 5.00

[Asserts]
exit-code == 0
stdout contains "Queijo Premium"
stdout contains "Queijo importado especial"

# --- Delete adicional ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{adicional_uuid}}

[Asserts]
exit-code == 0

# ============================================================
# Adicional Availability Toggle Tests
# ============================================================

# --- Create additional for availability test ---
RUN cargo run --quiet -p chickie-cli -- \
    create-adicional \
    --loja-uuid {{main_store_uuid}} \
    --nome "Disponivel Test" \
    --descricao "Test availability toggle" \
    --preco 2.00

[Captures]
disp_adicional_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Disponivel Test"

# --- List available add-ons (should include the new one) ---
RUN cargo run --quiet -p chickie-cli -- \
    list-adicionais-disponiveis \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Disponivel Test"

# --- Set additional as unavailable ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}} \
    --disponivel false

[Asserts]
exit-code == 0
stdout contains "indisponivel"

# --- List available add-ons (should NOT include the unavailable one) ---
RUN cargo run --quiet -p chickie-cli -- \
    list-adicionais-disponiveis \
    --loja-uuid {{main_store_uuid}}

[Asserts]
exit-code == 0
stdout not contains "Disponivel Test"

# --- Set additional as available again ---
RUN cargo run --quiet -p chickie-cli -- \
    toggle-disponibilidade-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}} \
    --disponivel true

[Asserts]
exit-code == 0
stdout contains "disponivel"

# --- Clean up ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-adicional \
    --loja-uuid {{main_store_uuid}} \
    --uuid {{disp_adicional_uuid}}

[Asserts]
exit-code == 0
