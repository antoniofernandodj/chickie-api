# ============================================================
# Category (Categoria) Tests
# Uses stores from previous tests
# ============================================================

# --- Create a category ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{category_store_uuid}} \
    --nome "Bebidas" \
    --descricao "Bebidas geladas" \
    --ordem 1

[Captures]
categoria_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0
stdout contains "Bebidas"
stdout contains "Bebidas geladas"

# --- Create category with pizza-mode ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{category_store_uuid}} \
    --nome "Pizzas Especiais" \
    --ordem 2 \
    --pizza-mode

[Asserts]
exit-code == 0
stdout contains "Pizzas Especiais"

# --- List categories ---
RUN cargo run --quiet -p chickie-cli -- \
    list-categorias \
    --loja-uuid {{category_store_uuid}}

[Asserts]
exit-code == 0
stdout contains "Bebidas"
stdout contains "Pizzas Especiais"

# --- Update category ---
RUN cargo run --quiet -p chickie-cli -- \
    update-categoria \
    --loja-uuid {{category_store_uuid}} \
    --uuid {{categoria_uuid}} \
    --nome "Bebidas Premium" \
    --ordem 3

[Asserts]
exit-code == 0
stdout contains "Bebidas Premium"

# --- Delete category (the one without products) ---
RUN cargo run --quiet -p chickie-cli -- \
    delete-categoria \
    --loja-uuid {{category_store_uuid}} \
    --uuid {{categoria_uuid}}

[Asserts]
exit-code == 0
