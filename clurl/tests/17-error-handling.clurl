# ============================================================
# Error Handling Tests
# Tests for invalid operations and edge cases
# ============================================================

# --- Test duplicate username ---
RUN cargo run --quiet -p chickie-cli -- \
    signup \
    --nome "Test User" \
    --username "testuser" \
    --senha "duplicatepass" \
    --email "duplicate@example.com" \
    --celular "11944444444"

[Asserts]
exit-code == 0

# --- Test invalid login ---
RUN cargo run --quiet -p chickie-cli -- \
    login \
    --identifier "nonexistent@example.com" \
    --senha "wrongpass"

[Asserts]
exit-code == 0
stderr contains "não encontrado"

# --- Test duplicate store slug ---
RUN cargo run --quiet -p chickie-cli -- \
    create-loja \
    --nome "Duplicate Store" \
    --slug "main-test-store" \
    --email-contato "dup@test.com" \
    --celular "11999999995" \
    --max-partes 4 \
    --criado-por {{admin_uuid}}

[Asserts]
exit-code == 0

