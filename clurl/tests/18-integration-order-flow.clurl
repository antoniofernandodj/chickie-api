# ============================================================
# Integration Tests - Complete Order Flow
# Uses users and stores from previous tests
# Tests the full lifecycle of an order from creation to delivery
# ============================================================

# --- Create category and product for order ---
RUN cargo run --quiet -p chickie-cli -- \
    create-categoria \
    --loja-uuid {{main_store_uuid}} \
    --nome "Integration Category" \
    --ordem 1

[Captures]
int_categoria_uuid: stdout regex /"uuid":\s*"([0-9a-f-]{36})"/

[Asserts]
exit-code == 0

RUN cargo run --quiet -p chickie-cli -- \
    create-produto \
    --loja-uuid {{main_store_uuid}} \
    --categoria-uuid {{int_categoria_uuid}} \
    --nome "Integration Product" \
    --preco 45.00 \
    --disponivel \
    --tempo-preparo-min 30

[Asserts]
exit-code == 0

# --- Create order ---
RUN cargo run --quiet -p chickie-cli -- \
    create-pedido \
    --usuario-uuid {{order_user_uuid}} \
    --loja-uuid {{main_store_uuid}} \
    --taxa-entrega 5.0 \
    --subtotal 45.0 \
    --forma-pagamento "PIX" \
    --observacoes "Integration test order"

[Captures]
integration_pedido_uuid: stdout regex /[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/

[Asserts]
exit-code == 0

# --- Create delivery address ---
RUN cargo run --quiet -p chickie-cli -- \
    create-endereco-entrega \
    --pedido-uuid {{integration_pedido_uuid}} \
    --loja-uuid {{main_store_uuid}} \
    --logradouro "Integration Street" \
    --numero "100" \
    --bairro "Integration District" \
    --cidade "Integration City" \
    --estado "SP" \
    --cep "12345-678"

[Asserts]
exit-code == 0
stdout contains "Integration Street"

# --- Get delivery address ---
RUN cargo run --quiet -p chickie-cli -- \
    get-endereco-entrega \
    {{integration_pedido_uuid}}

[Asserts]
exit-code == 0
stdout contains "Integration Street"
stdout contains "Integration City"

# --- State machine: Complete order lifecycle ---
# NOTE: Backend bug - "no column found for name: itens_json"
# Step 1: criado -> aguardando_confirmacao_de_loja
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "aguardando_confirmacao_de_loja"

[Asserts]
exit-code == 0
stdout contains "aguardando_confirmacao_de_loja"

# Step 2: aguardando_confirmacao_de_loja -> confirmado_pela_loja
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "confirmado_pela_loja"

[Asserts]
exit-code == 0
stdout contains "confirmado_pela_loja"

# Step 3: confirmado_pela_loja -> em_preparo
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "em_preparo"

[Asserts]
exit-code == 0
stdout contains "em_preparo"

# Step 4: em_preparo -> pronto_para_retirada
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "pronto_para_retirada"

[Asserts]
exit-code == 0
stdout contains "pronto_para_retirada"

# Step 5: pronto_para_retirada -> saiu_para_entrega
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "saiu_para_entrega"

[Asserts]
exit-code == 0
stdout contains "saiu_para_entrega"

# Step 6: saiu_para_entrega -> entregue (terminal state)
RUN cargo run --quiet -p chickie-cli -- \
    update-pedido-status \
    --uuid {{integration_pedido_uuid}} \
    --novo-status "entregue"

[Asserts]
exit-code == 0
stdout contains "entregue"
