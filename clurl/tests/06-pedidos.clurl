# RUN cargo run --quiet -p chickie-cli -- update-pedido-status --uuid {{pedido_uuid}} --novo-status "em_preparo"
#
# [Asserts]
# exit-code == 0
# stdout contains "em_preparo"

# --- Create delivery address for order ---
RUN cargo run --quiet -p chickie-cli -- create-endereco-entrega --pedido-uuid {{pedido_uuid}} --loja-uuid {{order_store_uuid}} --logradouro "Rua Test" --numero "123" --bairro "Centro" --cidade "São Paulo" --estado "SP" --cep "01001-000"

[Asserts]
exit-code == 0
stdout contains "Rua Test"
