# ============================================================
# smtp-server — Configurações de Ambiente
# ============================================================
# Copie este arquivo para .env e ajuste conforme necessário
# ============================================================

# Hostname do servidor (usado no greeting SMTP)
SMTP_HOSTNAME=localhost

# Portas de escuta (use portas acima de 1024 para rodar sem root)
SMTP_PORT=2525
SMTPS_PORT=4465
SMTP_SUBMISSION_PORT=2587

# Exige autenticação para envio de e-mails (recomendado: true)
REQUIRE_AUTH=true

# Credenciais padrão (em produção, use banco de dados)
SMTP_USERNAME=admin@localhost
SMTP_PASSWORD=troque-esta-senha-em-producao

# TLS — caminhos para os arquivos de certificado
TLS_CERT_PATH=certs/cert.pem
TLS_KEY_PATH=certs/key.pem

# Tamanho máximo da mensagem em bytes (padrão: 10MB)
MAX_MESSAGE_SIZE=10485760

# ============================================================
# Relay SMTP — configure para enviar e-mails de verdade
# ============================================================
# Sem relay configurado, o servidor apenas simula o envio nos logs

# Exemplo com MailerSend:
# RELAY_HOST=smtp.mailersend.net
# RELAY_PORT=587
# RELAY_USERNAME=seu-usuario@mailersend.net
# RELAY_PASSWORD=sua-api-key

# Exemplo com SendGrid:
# RELAY_HOST=smtp.sendgrid.net
# RELAY_PORT=587
# RELAY_USERNAME=apikey
# RELAY_PASSWORD=SG.sua-api-key

# Exemplo com Gmail (requer senha de app):
# RELAY_HOST=smtp.gmail.com
# RELAY_PORT=587
# RELAY_USERNAME=seu-email@gmail.com
# RELAY_PASSWORD=senha-de-app-16-chars

# ============================================================
# Logs
# ============================================================
# Níveis disponíveis: error, warn, info, debug, trace
RUST_LOG=smtp_server=debug,info
