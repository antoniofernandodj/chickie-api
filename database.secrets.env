# # ========== CREDENCIAIS ROOT (obrigatório) ==========
# MYSQL_ROOT_PASSWORD=SuaSenhaForteAqui123!

# # ========== BANCO E USUÁRIO DA APLICAÇÃO ==========
# # Cria um banco de dados automaticamente no primeiro boot
# MYSQL_DATABASE=chickie_db

# # Cria um usuário com permissões limitadas (recomendado para apps)
# MYSQL_USER=chickie_app
# MYSQL_PASSWORD=SenhaDoUsuarioApp456!

# # ========== CONFIGURAÇÕES OPCIONAIS DE SEGURANÇA ==========
# # Gera senha root aleatória na primeira inicialização (descomente para usar)
# # MYSQL_RANDOM_ROOT_PASSWORD=yes

# # Exige troca da senha root no primeiro login (MySQL 8+)
# # MYSQL_ONETIME_PASSWORD=yes

# # ========== REPLICACAO (opcional, para clusters) ==========
# # MYSQL_REPLICATION_MODE=master
# # MYSQL_REPLICATION_USER=repl_user
# # MYSQL_REPLICATION_PASSWORD=ReplSenha789!

# # ========== TIMEZONE E LOCALE ==========
# TZ=America/Sao_Paulo

POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase
POSTGRES_HOST=dokploy-postgres
POSTGRES_PORT=5432
